# Set default behavior to automatically normalize line endings
* text=auto

# Python files
*.py text eol=lf

# INO files (Arduino)
*.ino text eol=lf

# Markdown files
*.md text eol=lf

# Shell scripts
*.sh text eol=lf eol=lf

# Denote all files that are truly binary and should not be modified
*.png binary
*.jpg binary
*.pdf binary
*.zip binary
*.tar.gz binary
*.elf binary
*.hex binary
*.bin binary
